{
  "name": "gif-agent",
  "version": "1.0.0",
  "description": "Visual how-to GIF agent for technical questions",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "setup": "playwright install chromium",
    "keygen": "node scripts/keygen.mjs",
    "test": "echo \"No tests yet\"",
    "demo:screenshot": "npx playwright screenshot https://news.ycombinator.com/ demo-hn-screenshot.png --timeout 60000",
    "demo:next-step": "npm run build && node scripts/next-step-from-screenshot.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "openai": "^4.104.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
