PORT=3000
APP_ORIGIN=http://localhost:3000
# Optional: Postgres (e.g. Supabase). If unset, the app uses SQLite under DATA_DIR.
DATABASE_URL=
# SUPABASE_DATABASE_URL=
MASTER_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional override for screenshot analysis when using OpenAI (defaults to OPENAI_MODEL)
OPENAI_VISION_MODEL=
DATA_DIR=./data
# Email (magic links). Leave SMTP_HOST empty to log links to the server console instead.
# Resend: https://resend.com/docs/send-with-smtp — host smtp.resend.com, user resend, pass = API key
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Example for Resend without a custom domain: gif-agent <onboarding@resend.dev>
MAGIC_LINK_FROM=
